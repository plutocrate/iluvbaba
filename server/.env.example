# Database — Required for auth/community features
# Local Postgres example:
DATABASE_URL=postgres://postgres:password@localhost:5432/babaisfun

# Redis — Optional (feed caching). Leave blank to skip.
# REDIS_URL=redis://localhost:6379

# JWT Secret — change this to something random in production
JWT_SECRET=dev-secret-please-change-me-in-production

# Server port (Railway sets this automatically)
PORT=3001
